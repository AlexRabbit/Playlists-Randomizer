# Copy to .env and adjust
VITE_APP_NAME=Playlists Randomizer
VITE_BASE_PATH=/Playlists-Randomizer/
VITE_DEV_PORT=5173
VITE_DEFAULT_RANDOM=true
VITE_DEFAULT_SHOW_VIDEO=false
VITE_DEFAULT_NO_ADS=true
VITE_YOUTUBE_PLAYER_VARS=controls=1&rel=0&modestbranding=1
VITE_LOG_LEVEL=debug
VITE_LOG_MAX_ENTRIES=5000
VITE_URL_STATE_VERSION=1
VITE_DEFAULT_AUTOPLAY_NEXT=true
VITE_YOUTUBE_API_KEY=
# Optional playlist proxy — base64-encoded HTTPS URL (see docs/GITHUB-UPLOAD.md)
# VITE_PLAYLIST_PROXY_B64=
# Or plain URL for local dev only (.env, never commit):
# VITE_PLAYLIST_PROXY_URL=https://your-tunnel.example/
